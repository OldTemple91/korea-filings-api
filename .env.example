# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_PASSWORD=change_me_strong_password

# DART Open API
# Register at https://opendart.fss.or.kr/ to get a free API key.
DART_API_KEY=

# Google Gemini API
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# OpenAI API (fallback)
# Get from https://platform.openai.com/api-keys
OPENAI_API_KEY=

# x402 wallet (the wallet that RECEIVES payments)
# Generate a fresh wallet just for this service. Do not reuse a personal wallet.
# Only the address is needed for the app; the private key is only needed if you
# run a self-hosted facilitator, which we don't for the MVP.
X402_RECIPIENT_ADDRESS=0x0000000000000000000000000000000000000000

# x402 facilitator endpoint
# Use Coinbase's public facilitator for Base / Base Sepolia.
X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
X402_NETWORK=base

# Cloudflare Tunnel token (production only)
# Generate at Cloudflare dashboard > Zero Trust > Access > Tunnels
CLOUDFLARE_TUNNEL_TOKEN=

# Polling / runtime knobs
DART_POLL_INTERVAL_MS=30000
SUMMARY_JOB_MAX_CONCURRENCY=4
