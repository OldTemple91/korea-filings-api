# ─────────────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# Never commit .env to git.
# ─────────────────────────────────────────────────────────

# PostgreSQL
POSTGRES_PASSWORD=change_me_strong_password

# Redis — used for payment-replay keys, summary job queue, polling
# watermark. The server passes this through as SPRING_DATA_REDIS_PASSWORD,
# and the Redis container starts with --requirepass so co-tenant
# containers on the same docker network cannot read/write the cache.
REDIS_PASSWORD=change_me_strong_password

# DART Open API
# Register at https://opendart.fss.or.kr/ to get a free API key.
DART_API_KEY=

# Google Gemini API
# Get from https://aistudio.google.com/apikey
GEMINI_API_KEY=

# ─────────────────────────────────────────────────────────
# x402 payment protocol
# ─────────────────────────────────────────────────────────

# x402 recipient wallet. We only need the address here — the private key
# must NEVER land on the server (we receive, we don't sign).
X402_RECIPIENT_ADDRESS=0x0000000000000000000000000000000000000000

# ─── Testnet (Base Sepolia) ── use during Weeks 1–3 ──────
# Public community facilitator for testnet schemes; no auth required.
X402_FACILITATOR_URL=https://www.x402.org/facilitator
X402_NETWORK=eip155:84532
X402_ASSET=0x036CbD53842c5426634e7929541eC2318f3dCF7e

# ─── Mainnet (Base) ── replace the testnet block above with this for prod ──
# X402_FACILITATOR_URL=https://api.cdp.coinbase.com/platform/v2/x402
# X402_NETWORK=eip155:8453
# X402_ASSET=0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913

# EIP-712 token domain — must match exactly what the on-chain USDC
# contract returns from name() / version(). Base Sepolia USDC reports
# "USDC" / "2"; Base mainnet USDC reports "USD Coin" / "2". A mismatch
# reverts transferWithAuthorization with an opaque error at the
# facilitator. Always set both even on testnet — the X402PropertiesValidator
# refuses to start on mainnet without "USD Coin" here.
X402_TOKEN_NAME=USDC
X402_TOKEN_VERSION=2

# Coinbase CDP facilitator credentials — required ONLY for the mainnet
# Coinbase facilitator (Ed25519 JWT auth). Public x402.org testnet
# facilitator is auth-less, so leave empty on testnet. Generate at
# https://portal.cdp.coinbase.com/projects → API Keys → Create API Key
# → Ed25519 + all four scopes. Save the JSON download to ~/.cdp/x402.json
# (chmod 600) and copy the two fields. The FacilitatorClient signs a
# JWT per request and adds it as a Bearer header.
X402_CDP_KEY_ID=
X402_CDP_PRIVATE_KEY=

# ─────────────────────────────────────────────────────────
# Cloudflare Tunnel (production only)
# Generate at Cloudflare dashboard > Zero Trust > Access > Tunnels.
# The token lets cloudflared auto-connect this box to your tunnel.
# ─────────────────────────────────────────────────────────
CLOUDFLARE_TUNNEL_TOKEN=

# ─────────────────────────────────────────────────────────
# Runtime knobs
# ─────────────────────────────────────────────────────────
DART_POLL_INTERVAL_MS=30000
SUMMARY_JOB_MAX_CONCURRENCY=4

# ─────────────────────────────────────────────────────────
# Observability — opt-in request audit log
# When true, the app emits one REQ_AUDIT line per non-GET
# request OR any 4xx/5xx response. Captures structural fields
# only: method, path, status, IP, User-Agent, query parameter
# KEY names (never values), body size, content-type, and
# presence (boolean) of X-PAYMENT / PAYMENT-SIGNATURE headers.
# Used to quantify how often agents call paid GET endpoints
# with POST and whether they attach a payment payload, which
# informs whether to open parallel POST handlers. Off in dev
# and tests; turn on in prod when investigating traffic shape.
# ─────────────────────────────────────────────────────────
REQUEST_AUDIT_ENABLED=false

# Optional persistence layer on top of REQUEST_AUDIT_ENABLED. When
# true (and REQUEST_AUDIT_ENABLED is also true), every audited
# request is additionally written to the `request_audit` Postgres
# table via an async bounded-queue persister. Survives log rotation,
# powers funnel / KPI queries in docs/ANALYTICS.md. 90-day retention
# via nightly prune at 04:00 UTC. Has zero effect when
# REQUEST_AUDIT_ENABLED is false.
REQUEST_AUDIT_PERSIST=false
